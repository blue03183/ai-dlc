    "@types/multer": "^1.4.7",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.9",
    "@types/uuid": "^9.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.0"
